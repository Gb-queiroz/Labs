<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <title>Carros</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <div class="container">
        <h2>Carros Disponíveis</h2>
        <a href="/login"><button>Gerenciar</button></a>

        <div class="lista-posts">
            <% listaCarros.forEach(function(carro) { %>
                <div class="card-post">
                    <h2>
                        <%= carro.marca %> - <%= carro.modelo %>
                    </h2>
                    <p>Ano: <%= carro.ano %>
                    </p>
                    <% if (carro.qtde_disponivel===0) { %>
                        <p style="color: red; font-weight: bold;">Esgotado</p>
                        <% } else { %>
                            <p>Quantidade disponível: <%= carro.qtde_disponivel %>
                            </p>
                            <% } %>
                </div>
                <% }); %>
        </div>
    </div>
</body>

</html>