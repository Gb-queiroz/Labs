<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <title>Gerenciar Carros</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <div class="container">
        <h2>Cadastrar Novo Carro</h2>
        <label>Marca:</label><br>
        <input type="text" id="marca"><br><br>
        <label>Modelo:</label><br>
        <input type="text" id="modelo"><br><br>
        <label>Ano:</label><br>
        <input type="text" id="ano"><br><br>
        <label>Quantidade:</label><br>
        <input type="number" id="qtde"><br><br>
        <button onclick="cadastrarCarro()">Cadastrar</button>

        <hr>

        <h2>Carros Cadastrados</h2>
        <div class="lista-posts">
            <% listaCarros.forEach(function(carro) { %>
                <div class="card-post">
                    <h2>
                        <%= carro.marca %> - <%= carro.modelo %>
                    </h2>
                    <p>Ano: <%= carro.ano %>
                    </p>
                    <% if (carro.qtde_disponivel===0) { %>
                        <p style="color: red; font-weight: bold;">Esgotado</p>
                        <% } else { %>
                            <p>Quantidade: <%= carro.qtde_disponivel %>
                            </p>
                            <% } %>

                                <button onclick="vender('<%= carro._id %>')">Vender</button>
                                <button onclick="remover('<%= carro._id %>')">Remover</button>
                                <button
                                    onclick="preencherAtualizar('<%= carro._id %>', '<%= carro.marca %>', '<%= carro.modelo %>', '<%= carro.ano %>', '<%= carro.qtde_disponivel %>')">Atualizar</button>
                </div>
                <% }); %>
        </div>

        <hr>

        <h2 id="titulo-atualizar" style="display:none">Atualizar Carro</h2>
        <div id="form-atualizar" style="display:none">
            <input type="hidden" id="id-atualizar">
            <label>Marca:</label><br>
            <input type="text" id="marca-atualizar"><br><br>
            <label>Modelo:</label><br>
            <input type="text" id="modelo-atualizar"><br><br>
            <label>Ano:</label><br>
            <input type="text" id="ano-atualizar"><br><br>
            <label>Quantidade:</label><br>
            <input type="number" id="qtde-atualizar"><br><br>
            <button onclick="atualizar()">Salvar</button>
        </div>
    </div>

    <script>
        function cadastrarCarro() {
            const marca = document.getElementById('marca').value;
            const modelo = document.getElementById('modelo').value;
            const ano = document.getElementById('ano').value;
            const qtde = document.getElementById('qtde').value;

            fetch('/cadastrar_carro', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `marca=${encodeURIComponent(marca)}&modelo=${encodeURIComponent(modelo)}&ano=${encodeURIComponent(ano)}&qtde_disponivel=${encodeURIComponent(qtde)}`
            }).then(res => {
                if (res.redirected) window.location.href = res.url;
            });
        }

        function remover(id) {
            fetch('/remover_carro', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `id=${id}`
            }).then(res => {
                if (res.redirected) window.location.href = res.url;
            });
        }

        function vender(id) {
            fetch('/vender_carro', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `id=${id}`
            }).then(res => {
                if (res.redirected) window.location.href = res.url;
            });
        }

        function preencherAtualizar(id, marca, modelo, ano, qtde) {
            document.getElementById('titulo-atualizar').style.display = 'block';
            document.getElementById('form-atualizar').style.display = 'block';
            document.getElementById('id-atualizar').value = id;
            document.getElementById('marca-atualizar').value = marca;
            document.getElementById('modelo-atualizar').value = modelo;
            document.getElementById('ano-atualizar').value = ano;
            document.getElementById('qtde-atualizar').value = qtde;
        }

        function atualizar() {
            const id = document.getElementById('id-atualizar').value;
            const marca = document.getElementById('marca-atualizar').value;
            const modelo = document.getElementById('modelo-atualizar').value;
            const ano = document.getElementById('ano-atualizar').value;
            const qtde = document.getElementById('qtde-atualizar').value;

            fetch('/atualizar_carro', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `id=${id}&marca=${encodeURIComponent(marca)}&modelo=${encodeURIComponent(modelo)}&ano=${encodeURIComponent(ano)}&qtde_disponivel=${encodeURIComponent(qtde)}`
            }).then(res => {
                if (res.redirected) window.location.href = res.url;
            });
        }
    </script>
</body>

</html>